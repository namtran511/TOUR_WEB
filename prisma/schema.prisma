generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ConfirmationType {
  INSTANT
  MANUAL
}

enum PaymentMethod {
  PAY_NOW
  PAY_LATER
  PAY_AT_DESTINATION
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum VoucherType {
  PERCENT
  FIXED
}

model User {
  id            Int      @id @default(autoincrement())
  full_name     String   @db.VarChar(100)
  email         String   @unique @db.VarChar(150)
  password_hash String   @db.VarChar(255)
  role          UserRole @default(USER)
  avatar_url    String?  @db.VarChar(255)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  spots_created Spot[]          @relation("SpotCreatedBy")
  favorites     Favorite[]
  reviews       Review[]
  searchHistory SearchHistory[]
  bookings      Booking[]

  @@map("users")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  icon        String?  @db.VarChar(255)
  created_at  DateTime @default(now())

  spots Spot[]

  @@map("categories")
}

model Spot {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(150)
  description    String?  @db.Text
  address        String   @db.VarChar(255)
  city           String   @db.VarChar(100)
  latitude       Float
  longitude      Float
  category_id    Int
  image_url      String?  @db.VarChar(255)
  opening_hours  String?  @db.VarChar(100)
  ticket_price   Decimal? @db.Decimal(10, 2)
  average_rating Float    @default(0)
  created_by     Int
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  category   Category        @relation(fields: [category_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  creator    User            @relation("SpotCreatedBy", fields: [created_by], references: [id], onDelete: Restrict, onUpdate: Cascade)
  favorites  Favorite[]
  reviews    Review[]
  images     SpotImage[]
  bookings   Booking[]
  packages   SpotPackage[]
  rooms      SpotRoom[]
  departures SpotDeparture[]

  @@index([category_id])
  @@index([created_by])
  @@index([city])
  @@index([latitude, longitude])
  @@map("spots")
}

model Favorite {
  id         Int      @id @default(autoincrement())
  user_id    Int
  spot_id    Int
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  spot Spot @relation(fields: [spot_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([user_id, spot_id])
  @@index([user_id])
  @@index([spot_id])
  @@map("favorites")
}

model Review {
  id         Int      @id @default(autoincrement())
  user_id    Int
  spot_id    Int
  rating     Int
  comment    String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  spot Spot @relation(fields: [spot_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([user_id, spot_id])
  @@index([user_id])
  @@index([spot_id])
  @@map("reviews")
}

model SpotImage {
  id         Int     @id @default(autoincrement())
  spot_id    Int
  image_url  String  @db.VarChar(255)
  is_primary Boolean @default(false)

  spot Spot @relation(fields: [spot_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([spot_id])
  @@map("spot_images")
}

model SearchHistory {
  id          Int      @id @default(autoincrement())
  user_id     Int
  keyword     String?  @db.VarChar(150)
  latitude    Float?
  longitude   Float?
  searched_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([user_id])
  @@index([keyword])
  @@map("search_histories")
}

model SpotPackage {
  id                       Int      @id @default(autoincrement())
  spot_id                  Int
  name                     String   @db.VarChar(150)
  description              String?  @db.Text
  price                    Decimal  @db.Decimal(10, 2)
  duration_minutes         Int?
  meeting_point            String?  @db.VarChar(255)
  pickup_included          Boolean  @default(false)
  pickup_note              String?  @db.VarChar(255)
  pickup_area              String?  @db.VarChar(255)
  free_cancel_before_hours Int      @default(48)
  refund_percent_before    Int      @default(100)
  refund_percent_after     Int      @default(0)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  spot Spot @relation(fields: [spot_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  bookings Booking[]

  @@index([spot_id])
  @@map("spot_packages")
}

model SpotRoom {
  id                       Int      @id @default(autoincrement())
  spot_id                  Int
  name                     String   @db.VarChar(150)
  description              String?  @db.Text
  price                    Decimal  @db.Decimal(10, 2)
  quantity                 Int      @default(0)
  free_cancel_before_hours Int      @default(48)
  refund_percent_before    Int      @default(100)
  refund_percent_after     Int      @default(0)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  spot Spot @relation(fields: [spot_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  bookings Booking[]

  @@index([spot_id])
  @@map("spot_rooms")
}

model SpotDeparture {
  id                Int              @id @default(autoincrement())
  spot_id           Int
  label             String           @db.VarChar(120)
  start_time        DateTime
  end_time          DateTime
  capacity          Int              @default(0)
  booked_count      Int              @default(0)
  confirmation_type ConfirmationType @default(MANUAL)
  is_active         Boolean          @default(true)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  spot     Spot      @relation(fields: [spot_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bookings Booking[]

  @@index([spot_id])
  @@index([start_time])
  @@map("spot_departures")
}

model Voucher {
  id                 Int         @id @default(autoincrement())
  code               String      @unique @db.VarChar(50)
  name               String      @db.VarChar(120)
  description        String?     @db.Text
  type               VoucherType
  value              Decimal     @db.Decimal(10, 2)
  max_discount       Decimal?    @db.Decimal(10, 2)
  min_booking_amount Decimal?    @db.Decimal(10, 2)
  usage_limit        Int?
  used_count         Int         @default(0)
  expires_at         DateTime?
  is_active          Boolean     @default(true)
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  bookings Booking[]

  @@map("vouchers")
}

model Booking {
  id                     Int              @id @default(autoincrement())
  user_id                Int
  spot_id                Int
  package_id             Int?
  room_id                Int?
  departure_id           Int?
  voucher_id             Int?
  date                   DateTime
  end_date               DateTime         @default(now())
  guests                 Int              @default(1)
  tour_days              Int              @default(1)
  room_count             Int              @default(1)
  subtotal_price         Decimal?         @db.Decimal(12, 2)
  discount_amount        Decimal?         @db.Decimal(12, 2)
  total_price            Decimal?         @db.Decimal(12, 2)
  refund_amount          Decimal?         @db.Decimal(12, 2)
  status                 BookingStatus    @default(PENDING)
  payment_method         PaymentMethod    @default(PAY_NOW)
  confirmation_type      ConfirmationType @default(MANUAL)
  expires_at             DateTime?
  confirmed_at           DateTime?
  cancelled_at           DateTime?
  rejection_reason       String?          @db.Text
  cancellation_reason    String?          @db.Text
  notes                  String?          @db.Text
  booking_code           String           @unique @db.VarChar(40)
  ticket_code            String?          @unique @db.VarChar(60)
  qr_value               String?          @db.VarChar(120)
  pickup_requested       Boolean          @default(false)
  pickup_address         String?          @db.VarChar(255)
  meeting_point_snapshot String?          @db.VarChar(255)
  created_at             DateTime         @default(now())
  updated_at             DateTime         @updatedAt

  user      User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  spot      Spot           @relation(fields: [spot_id], references: [id], onDelete: Cascade)
  package   SpotPackage?   @relation(fields: [package_id], references: [id], onDelete: SetNull)
  room      SpotRoom?      @relation(fields: [room_id], references: [id], onDelete: SetNull)
  departure SpotDeparture? @relation(fields: [departure_id], references: [id], onDelete: SetNull)
  voucher   Voucher?       @relation(fields: [voucher_id], references: [id], onDelete: SetNull)
  payment   Payment?

  @@index([user_id])
  @@index([spot_id])
  @@index([package_id])
  @@index([room_id])
  @@index([departure_id])
  @@index([voucher_id])
  @@map("bookings")
}

model Payment {
  id               Int           @id @default(autoincrement())
  booking_id       Int           @unique
  amount           Decimal       @db.Decimal(12, 2)
  method           PaymentMethod
  status           PaymentStatus @default(UNPAID)
  due_at           DateTime?
  paid_at          DateTime?
  refunded_at      DateTime?
  transaction_code String?       @unique @db.VarChar(80)
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@map("payments")
}
